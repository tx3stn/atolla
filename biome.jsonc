{
	"$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on",
				"preset": "recommended",
				"useSortedAttributes": "on",
				"useSortedInterfaceMembers": "on",
				"useSortedKeys": "on"
			}
		},
		"enabled": true,
		"includes": ["**"]
	},
	"files": {
		"ignoreUnknown": true,
		"includes": ["**", "!**/assets", "!!**/build", "!!**/coverage", "!!**/dist"]
	},
	"formatter": {
		"enabled": true,
		"lineWidth": 100,
		"useEditorconfig": true
	},
	"javascript": {
		"formatter": {
			"indentStyle": "tab",
			"jsxQuoteStyle": "single",
			"quoteStyle": "single"
		}
	},
	"linter": {
		"domains": {
			"test": "recommended"
		},
		"enabled": true,
		"rules": {
			"a11y": {
				"noLabelWithoutControl": "off",
				"noStaticElementInteractions": "off"
			},
			"complexity": {
				"useDateNow": "warn"
			},
			"correctness": {
				"noUnusedImports": "error",
				"noUnusedVariables": "warn"
			},
			"nursery": {},
			"preset": "recommended",
			"style": {
				"noYodaExpression": "warn",
				"useConsistentArrayType": {
					"level": "warn",
					"options": {
						"syntax": "generic"
					}
				},
				"useNumberNamespace": "warn",
				"useThrowNewError": "warn"
			},
			"suspicious": {
				"noDebugger": "error",
				"useAwait": "error"
			}
		}
	},
	"overrides": [
		{
			"includes": ["**/*.spec.ts", "**/*.spec.tsx"],
			"linter": {
				"rules": {
					"suspicious": {
						"useAwait": "off"
					}
				}
			}
		},
		{
			"includes": ["**/*.svg"],
			"linter": {
				"rules": {
					"a11y": {
						"noSvgWithoutTitle": "off"
					}
				}
			}
		}
	],
	"vcs": {
		"clientKind": "git",
		"defaultBranch": "main",
		"enabled": true,
		"useIgnoreFile": true
	}
}
