common --enable_platform_specific_config
common --experimental_worker_for_repo_fetching=off
common --experimental_google_legacy_api=true
common --experimental_enable_android_migration_apis=true
common --incompatible_java_common_parameters=false
common --repository_cache=~/.cache/bazel-repo

build --tool_java_language_version=11
build --java_language_version=11
build --javacopt=-XepDisableAllChecks
build --macos_minimum_os=12.0
build --host_macos_minimum_os=12.0
build --ios_minimum_os=12.0
build --define=enable_web=true
build --java_runtime_version=remotejdk_21
build --tool_java_runtime_version=remotejdk_21
build --cxxopt=-std=gnu++20
build --host_cxxopt=-std=gnu++20
# Clang 26 (SDK 26+) promotes several warnings to errors in third-party deps (abseil, Hermes, Yoga)
build --host_copt=-Wno-deprecated-builtins
build --host_copt=-Wno-deprecated-literal-operator
build --host_copt=-Wno-nontrivial-memcall
build --host_copt=-Wno-deprecated
build --copt=-Wno-deprecated-builtins
build --copt=-Wno-deprecated-literal-operator
build --copt=-Wno-nontrivial-memcall
build --copt=-Wno-deprecated
build --flag_alias=snap_flavor=@snap_platforms//flavors:snap_flavor
build --snap_flavor=platform_development
build --flag_alias=valdi_js_engine=@valdi//bzl/valdi:js_engine
build --valdi_js_engine=hermes
build --define=open_source_build=true
build --disk_cache=~/.cache/bazel-disk

# Parallelism — 2× cores keeps actions flowing on I/O-bound builds; RAM governs actual concurrency
build --jobs=HOST_CPUS*2
build --local_resources=cpu=HOST_CPUS
build --local_resources=memory=HOST_RAM*.8

# Persistent Kotlin compiler daemon — eliminates JVM startup cost per compile action
build --strategy=KotlinCompile=worker

# Sandbox perf — reuse directory trees between actions instead of recreating them
build --experimental_reuse_sandbox_directories

# Halves runfile symlink I/O on macOS
build --nolegacy_external_runfiles

# FSEvents-based change detection for faster incremental input scanning
build --watchfs

# Don't inherit shell PATH into action env — dynamic entries (fnm_multishells, etc.)
# change every session and bust the entire disk cache
build --incompatible_strict_action_env

# Android-specific — applied via --config=android in start-android-emulator.sh
build:android --copt=-DANDROID_WITH_JNI
build:android --repo_env=VALDI_PLATFORM_DEPENDENCIES=android
build:android --define=client_repo_arm64=true
build:android --fat_apk_cpu=arm64-v8a
build:android --android_cpu=arm64-v8a
build:android --android_crosstool_top=@androidndk//:toolchain
build:android --define=android_dexmerger_tool=d8_dexmerger
build:android --define=android_incremental_dexing_tool=d8_dexbuilder
build:android --define=android_standalone_dexing_tool=d8_compat_dx
build:android --incremental_dexing
# macOS sandbox-exec has 200-400ms overhead per action — skip it for dev targets
build:android --spawn_strategy=local
build:android --strategy=ValdiCompile=local

# iOS-specific — applied via --config=ios in start-ios-simulator.sh
build:ios --spawn_strategy=local
build:ios --strategy=ValdiCompile=local

test --spawn_strategy=local
test --strategy=TestRunner=local
