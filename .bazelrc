# Valdi custom Bazel registry (pre-patched rules_swift, rules_kotlin, etc.),
# then the Bazel Central Registry. Order matters: Valdi's registry wins.
common --registry=https://raw.githubusercontent.com/Snapchat/Valdi/beta-0.1.0/registry
common --registry=https://bcr.bazel.build

common --enable_platform_specific_config
common --experimental_worker_for_repo_fetching=off
common --experimental_google_legacy_api=true
common --experimental_enable_android_migration_apis=true
common --incompatible_java_common_parameters=false
common --repository_cache=~/.cache/bazel-repo

# Host tools (rules_android's android_builder etc.) use Java records, which need
# source 16+; app bytecode still targets 11 for Android. Matches Valdi.
build --tool_java_language_version=17
build --java_language_version=11
build --javacopt=-XepDisableAllChecks
build --macos_minimum_os=12.0
build --host_macos_minimum_os=12.0
build --ios_minimum_os=12.0
build --define=enable_web=true
build --java_runtime_version=remotejdk_21
build --tool_java_runtime_version=remotejdk_21
build --cxxopt=-std=gnu++20
build --host_cxxopt=-std=gnu++20
# Valdi sources use the Clang nullability extension; silence the warning (matches
# the beta-0.1.0 bootstrap template).
build --cxxopt=-Wno-nullability-extension
build --host_cxxopt=-Wno-nullability-extension
# Clang 26 (SDK 26+) promotes several warnings to errors in third-party deps (abseil, Hermes, Yoga)
build --host_copt=-Wno-deprecated-builtins
build --host_copt=-Wno-deprecated-literal-operator
build --host_copt=-Wno-nontrivial-memcall
build --host_copt=-Wno-deprecated
build --copt=-Wno-deprecated-builtins
build --copt=-Wno-deprecated-literal-operator
build --copt=-Wno-nontrivial-memcall
build --copt=-Wno-deprecated
# Hermetic linux clang predates Clang 26 and doesn't know the -Wno flags above;
# without this, targets built with -Werror (protobuf) fail on -Wunknown-warning-option
build:linux --copt=-Wno-unknown-warning-option
build:linux --host_copt=-Wno-unknown-warning-option
build --flag_alias=snap_flavor=@snap_platforms//flavors:snap_flavor
build --snap_flavor=platform_development
build --flag_alias=valdi_js_engine=@valdi//bzl/valdi:js_engine
build --valdi_js_engine=hermes
build --define=open_source_build=true
build --disk_cache=~/.cache/bazel-disk

# Parallelism — 2× cores keeps actions flowing on I/O-bound builds; RAM governs actual concurrency
build --jobs=HOST_CPUS*2
build --local_resources=cpu=HOST_CPUS
build --local_resources=memory=HOST_RAM*.8

# Persistent Kotlin compiler daemon — eliminates JVM startup cost per compile action
build --strategy=KotlinCompile=worker

# The Valdi compiler is always invoked with --persistent_worker_protocol
# (valdi_run_compiler.bzl), so it must run as a Bazel-managed worker. Running it
# standalone (e.g. via spawn_strategy=local) makes it treat the worker flag as a
# second mode flag and fail ("Must provide only one of: --compile OR ..."). Force
# the worker strategy so it wins over the per-config local spawn strategies below.
build --strategy=ValdiCompile=worker

# Sandbox perf — reuse directory trees between actions instead of recreating them
build --experimental_reuse_sandbox_directories

# Skymeld — interleave analysis with execution instead of running them as
# strict phases; CI component-tests spend ~6.5 min in analysis alone
build --experimental_merged_skyframe_analysis_execution

# Halves runfile symlink I/O on macOS
build --nolegacy_external_runfiles

# FSEvents-based change detection for faster incremental input scanning
build --watchfs

# Don't inherit shell PATH into action env — dynamic entries (fnm_multishells, etc.)
# change every session and bust the entire disk cache
build --incompatible_strict_action_env

# Remote cache — CI opts in by appending to ~/.bazelrc when the
# BUILDBUDDY_API_KEY secret exists (the key itself never lives in this file).
# Local builds can opt in too with a personal key via ~/.bazelrc.
build:remote-cache --remote_cache=grpcs://remote.buildbuddy.io
build:remote-cache --remote_timeout=3600
build:remote-cache --remote_cache_compression
# Build without the Bytes — on a cache hit, don't pull every action's outputs onto the
# runner; BuildBuddy keeps the blobs and only inputs that local actions actually need are
# fetched on demand. Cuts the "download every cache hit" stall on cold or MR-delta builds
# that fall back to the remote cache instead of a warm output base.
build:remote-cache --remote_download_toplevel
# BuildBuddy-suggested: don't zstd blobs the compression would inflate, and
# strip duplicate file references from the build event stream
build:remote-cache --experimental_remote_cache_compression_threshold=100
build:remote-cache --nolegacy_important_outputs
# don't block invocation exit on the build event stream finishing its upload
build:remote-cache --bes_upload_mode=nowait_for_upload_complete
build:remote-cache --bes_backend=grpcs://remote.buildbuddy.io
build:remote-cache --bes_results_url=https://app.buildbuddy.io/invocation/

# Android-specific — applied via --config=android in start-android-emulator.sh
build:android --disk_cache=~/.cache/bazel-disk-android
build:android --copt=-DANDROID_WITH_JNI
build:android --repo_env=VALDI_PLATFORM_DEPENDENCIES=android
build:android --define=client_repo_arm64=true
build:android --fat_apk_cpu=arm64-v8a
build:android --android_cpu=arm64-v8a
build:android --define=android_dexmerger_tool=d8_dexmerger
build:android --define=android_incremental_dexing_tool=d8_dexbuilder
build:android --define=android_standalone_dexing_tool=d8_compat_dx
build:android --incremental_dexing
# macOS sandbox-exec has 200-400ms overhead per action — skip it for dev targets
build:android --spawn_strategy=local

# iOS-specific — applied via --config=ios in start-ios-simulator.sh
build:ios --disk_cache=~/.cache/bazel-disk-ios
build:ios --spawn_strategy=local

test --spawn_strategy=local
test --strategy=TestRunner=local

build:prod --define=build_mode=prod

# Per-machine settings (gitignored) — e.g. a personal remote-cache key
try-import %workspace%/.bazelrc.user
