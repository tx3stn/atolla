{
	"dependencies": {},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@snap/valdi": "^1.0.11",
		"@types/bun": "^1.3.14",
		"@types/node": "^24.12.4",
		"@wdio/appium-service": "^9.27.1",
		"@wdio/cli": "^9.27.1",
		"@wdio/globals": "^9.27.1",
		"@wdio/local-runner": "^9.27.1",
		"@wdio/mocha-framework": "^9.27.2",
		"@wdio/spec-reporter": "^9.27.1",
		"appium": "^3.4.2",
		"appium-inspector-plugin": "^2026.5.1",
		"appium-uiautomator2-driver": "^7.4.0",
		"appium-xcuitest-driver": "^11.4.2",
		"sharp": "^0.34.5",
		"typescript": "^6.0.3",
		"webdriverio": "^9.27.1"
	},
	"name": "atolla",
	"private": true,
	"scripts": {
		"adb:reload": "adb shell am force-stop com.tx3stn.atolla && adb shell monkey -p com.tx3stn.atolla -c android.intent.category.LAUNCHER 1",
		"android": "./.scripts/start-android-emulator.sh",
		"android:fast": "FAST_DEV_BUILD=1 ./.scripts/start-android-emulator.sh",
		"appium:inspect": "./.scripts/start-appium-inspector.sh",
		"check": "bun run format && bun run lint && bun run compile && bun run test && bun run format:zig && bun run check:zig && bun run test:zig && bun run test:android && bun run test:ios",
		"check:full": "./.scripts/check-full.sh",
		"check:zig": "bazel build //atolla/native/zig:atolla_algorithms_zig",
		"compile": "bunx tsc --noEmit -p tsconfig.json && bunx tsc --noEmit -p atolla/tsconfig.src.json && bunx tsc --noEmit -p atolla/tsconfig.tests.json",
		"format": "biome format --write .",
		"format:zig": "zig fmt ./atolla/native/zig/",
		"icons:generate": "bun ./.scripts/generate-icons.ts",
		"ios": "./.scripts/start-ios-simulator.sh",
		"ios:fast": "FAST_DEV_BUILD=1 ./.scripts/start-ios-simulator.sh",
		"lint": "biome check --write --assist-enabled=true --enforce-assist=true --unsafe .",
		"reload": "./.scripts/android-hotreload.sh",
		"start:e2e-devices": "./.scripts/start-e2e-devices.sh",
		"test": "bun test ./atolla/src",
		"test:android": "bazel test //atolla/native/android/test/... --legacy_external_runfiles --test_output=streamed --test_summary=short --noshow_loading_progress --show_result=0 --test_verbose_timeout_warnings",
		"test:components": "bazel test //atolla:test --test_output=streamed --test_summary=short --noshow_loading_progress --show_result=0 --test_verbose_timeout_warnings",
		"test:e2e": "./.scripts/test-e2e-parallel.sh",
		"test:e2e:android": "E2E_APP_PATH=$PWD/build/atolla_android.apk wdio run ./e2e/wdio.conf.ts",
		"test:e2e:ios": "E2E_PLATFORM=iOS E2E_APP_PATH=$PWD/build/atolla_ios.ipa wdio run ./e2e/wdio.conf.ts",
		"test:e2e:smoke": "E2E_ANDROID_APP_PATH=$PWD/build/atolla_android.apk E2E_IOS_APP_PATH=$PWD/build/atolla_ios.ipa wdio run ./e2e/wdio.conf.parallel.ts --spec e2e/tests/smoke",
		"test:ios": "bazel test //atolla/native/ios/test/... --test_output=streamed --test_summary=short --noshow_loading_progress --show_result=0 --test_verbose_timeout_warnings",
		"test:zig": "./.scripts/test-zig.sh"
	},
	"version": "0.0.1"
}
