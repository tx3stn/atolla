{
	"dependencies": {},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@snap/valdi": "^1.0.7",
		"@types/bun": "^1.3.10",
		"@types/node": "^24.5.2",
		"@wdio/appium-service": "^9.0.0",
		"@wdio/cli": "^9.26.1",
		"@wdio/globals": "^9.26.1",
		"@wdio/local-runner": "^9.0.0",
		"@wdio/mocha-framework": "^9.25.0",
		"@wdio/spec-reporter": "^9.26.0",
		"appium": "^3.2.2",
		"appium-inspector-plugin": "^2026.2.1",
		"appium-uiautomator2-driver": "^7.0.0",
		"appium-xcuitest-driver": "^11.0.0",
		"sharp": "^0.34.5",
		"typescript": "^5.9.2",
		"webdriverio": "^9.26.0"
	},
	"name": "atolla",
	"private": true,
	"scripts": {
		"adb:reload": "adb shell am force-stop com.tx3stn.atolla && adb shell monkey -p com.tx3stn.atolla -c android.intent.category.LAUNCHER 1",
		"android": "bun run icons:generate && /.scripts/start-android-emulator.sh",
		"android:fast": "FAST_DEV_BUILD=1 ./.scripts/start-android-emulator.sh",
		"appium:inspect": "./.scripts/start-appium-inspector.sh",
		"check": "bun run format && bun run lint && bun run compile && bun run test && bun run format:zig && bun run check:zig && bun run test:zig",
		"check:full": "bun run check && bun run test:components && bun run android:fast && bun run ios:fast && bun run test:e2e",
		"check:zig": "bazel build //atolla/native/zig:atolla_algorithms_zig",
		"compile": "bunx tsc --noEmit",
		"format": "biome format --write .",
		"format:zig": "zig fmt ./atolla/native/zig/",
		"icons:generate": "bun ./.scripts/generate-icons.ts",
		"ios": "bun run icons:generate && ./.scripts/start-ios-simulator.sh",
		"ios:fast": "FAST_DEV_BUILD=1 ./.scripts/start-ios-simulator.sh",
		"lint": "biome check --write --assist-enabled=true --enforce-assist=true --unsafe .",
		"reload": "./.scripts/android-hotreload.sh",
		"test": "bun test ./atolla/src",
		"test:components": "bazel test //atolla:test --test_output=streamed --test_summary=short --noshow_loading_progress --show_result=0 --test_verbose_timeout_warnings",
		"test:e2e": "E2E_ANDROID_APP_PATH=$PWD/build/atolla_android.apk E2E_IOS_APP_PATH=$PWD/build/atolla_ios.ipa wdio run ./test/wdio.conf.parallel.ts",
		"test:e2e:android": "E2E_APP_PATH=$PWD/build/atolla_android.apk wdio run ./test/wdio.conf.ts",
		"test:e2e:ios": "E2E_PLATFORM=iOS E2E_APP_PATH=$PWD/build/atolla_ios.ipa wdio run ./test/wdio.conf.ts",
		"test:zig": "./.scripts/test-zig.sh"
	},
	"version": "0.0.1"
}
